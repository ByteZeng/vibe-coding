# 复制为 .env 后填写。勿将 .env 提交到仓库。

# 服务端口（本地默认 3001；Railway 等平台会注入 PORT，勿写死）
PORT=3001

# 监听地址：本地可省略；Railway 等必须绑定 0.0.0.0（代码默认已是 0.0.0.0）
# HOST=0.0.0.0

# DeepSeek（必填，仅服务端使用）
DEEPSEEK_API_KEY=

# 可选，默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# 可选：允许跨域的前端地址，英文逗号分隔。默认仅 localhost:5173 / 5174。
# 用手机局域网 IP 访问前端时，需加入对应 origin，例如：
# CORS_ORIGINS=http://localhost:5173,http://192.168.1.4:5173
