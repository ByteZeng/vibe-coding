# 复制为 .env 后填写。勿将 .env 提交到仓库。

# 服务端口（本地默认 3001；Railway 等平台会注入 PORT，勿写死）
PORT=3001

# 监听地址：本地可省略；Railway 等必须绑定 0.0.0.0（代码默认已是 0.0.0.0）
# HOST=0.0.0.0

# DeepSeek（必填，仅服务端使用）
DEEPSEEK_API_KEY=

# 可选，默认 https://api.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选，默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat

# 可选：允许跨域的前端地址，英文逗号分隔。默认仅 localhost:5173 / 5174。
# Vercel 部署示例（把域名换成你的实际地址，含 https://，无尾斜杠）：
# CORS_ORIGINS=http://localhost:5173,https://你的项目.vercel.app
# 或一键允许所有 Vercel 子域（预览 URL 也会变，用这个省事）：
# CORS_ALLOW_VERCEL=true
