/**
 * 用法：复制为 ecosystem.config.cjs 放到 backend 目录，或调整 cwd 后：
 *   pm2 start ecosystem.config.cjs
 * 部署前先在服务器配置 backend/.env
 *
 * 若 git clone 未使用末尾「.」，仓库多在 /opt/haigui/vibe-coding/，cwd 如下；
 * 若克隆到 /opt/haigui/ 根目录，请把 cwd 改为 /opt/haigui/backend
 */
module.exports = {
  apps: [
    {
      name: 'haigui-api',
      cwd: '/opt/haigui/vibe-coding/backend',
      script: 'server.js',
      instances: 1,
      exec_mode: 'fork',
      env: {
        NODE_ENV: 'production',
      },
    },
  ],
}
